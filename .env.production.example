# ===========================================
# AfricaVet CMS - Production Environment
# ===========================================
# Copy this file to .env and fill in the values

# Domain
DOMAIN=africavet.com

# GitHub (for pulling images)
GITHUB_REPOSITORY=your-username/africavet-cms

# Database
DB_ROOT_PASSWORD=your-secure-root-password
DB_NAME=africavet_cms
DB_USER=africavet_user
DB_PASSWORD=your-secure-db-password

# JWT Secret (generate with: openssl rand -base64 64)
JWT_SECRET=your-super-secret-jwt-key-at-least-64-characters-long

# CORS Origins (comma-separated, optional - defaults are set in server.js)
# CORS_ORIGINS=https://africavet.com,https://www.africavet.com,https://admin.africavet.com

# Email Configuration (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@africavet.com

# Let's Encrypt Email (for SSL certificate notifications)
LETSENCRYPT_EMAIL=admin@africavet.com

# ===========================================
# DO NOT commit this file with real values!
# ===========================================
